Cell["\<\
Also, you don\[CloseCurlyQuote]t have to use strings to refer to properties. \
You can always write characters and they will be automatically converted to \
lowercase property names:\
\>", "Text",
 CellChangeTimes->{
  3.9129212502116513`*^9},ExpressionUUID->"be3cf272-2aee-49b5-8443-\
a823d7c5d1ae"],

