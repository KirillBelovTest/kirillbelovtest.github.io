Cell["\<\
Another important property of properties (pardon the pun) is that they can be \
set with deferred execution. This is essentially analogous to getters from \
Java or C#. Here\[CloseCurlyQuote]s how it can be done:\
\>", "Text",
 CellChangeTimes->{
  3.9129217876614265`*^9},ExpressionUUID->"f2c7635a-765f-4c19-8d32-\
51bb65a9b26b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"obj1", "[", "\"\<Random\>\"", "]"}], ":=", 
  RowBox[{"RandomReal", "[", "]"}]}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"obj1", "[", "\"\<Random\>\"", "]"}], ",", 
   RowBox[{"obj1", "[", "\"\<Random\>\"", "]"}], ",", 
   RowBox[{"obj1", "[", "\"\<Random\>\"", "]"}]}], "}"}]}], "Input",
 CellChangeTimes->{{3.912921797233838*^9, 3.912921797642725*^9}},
 CellLabel->"In[29]:=",ExpressionUUID->"15c3e670-3817-4b63-a662-1769c4a0729c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.4097085835462595`", ",", "0.34892876125280625`", ",", 
   "0.4215425076549877`"}], "}"}]], "Output",
 CellChangeTimes->{3.9129217980832357`*^9},
 CellLabel->"Out[30]=",ExpressionUUID->"9f0691f6-3f11-4ea5-bf41-c113b963e24d"]
}, Open  ]],

Cell["\<\
Each time we access such a property, we will compute the right-hand side anew.\
\>", "Text",
 CellChangeTimes->{
  3.912921811291642*^9},ExpressionUUID->"bf1c27dd-8e38-4b30-b6f8-\
7bd56a6471bf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Inheritance", "Section",
 CellChangeTimes->{
  3.912921822218569*^9},ExpressionUUID->"0eb4f7a4-c349-4e92-abd8-\
a1a7846bbf6b"],

Cell[TextData[{
 "What good are mutable objects if you can\[CloseCurlyQuote]t build a type \
hierarchy from them. In order to create a new type-descendant from some \
existing type, I added the ",
 StyleBox["CreateType",
  FontWeight->"Bold"],
 " function. Here\[CloseCurlyQuote]s how you can use it:"
}], "Text",
 CellChangeTimes->{
  3.9129218375157747`*^9},ExpressionUUID->"2c7e735f-7304-4082-9761-\
9a76a34ef851"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"CreateType", "[", 
    RowBox[{"type", ",", "parent", ",", "init", ",", 
     RowBox[{"{", "fields", "}"}]}], "]"}], "*)"}], 
  RowBox[{
   RowBox[{"CreateType", "[", 
    RowBox[{"Human", ",", "Object", ",", "Identity", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Name\>\"", ",", "Age", ",", 
       RowBox[{"\"\<Country\>\"", "->", 
