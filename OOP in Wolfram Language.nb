Cell["\<\
What really happened here? The CLR method table creates two definitions for \
this class that have different signatures - i.e. method name + types and \
number of arguments. Is it possible to do something like this in WL? Of \
course yes!\
\>", "Text",
 CellChangeTimes->{
  3.9129223904913826`*^9},ExpressionUUID->"a426e9e6-9092-4856-8543-\
c8510aa81ca2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{"sayHi", "[", 
    RowBox[{"human_Human", ",", "postfix_String"}], "]"}], ":=", 
   RowBox[{"Echo", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringTemplate", "[", "\"\<Hi! My name is `1`. `2`\>\"", "]"}],
       "[", 
      RowBox[{
       RowBox[{"human", "[", "\"\<Name\>\"", "]"}], ",", "postfix"}], "]"}], 
     ",", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"human", "[", "\"\<Name\>\"", "]"}], ",", "\"\< says: \>\""}],
        "}"}], "]"}]}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"sayHi", "[", "Kirill", "]"}], "\n", 
 RowBox[{"sayHi", "[", 
  RowBox[{"Kirill", ",", "\"\<What is your name?\>\""}], "]"}]}], "Input",
 CellChangeTimes->{{3.91292239816878*^9, 3.91292239816878*^9}},
 CellLabel->"In[51]:=",ExpressionUUID->"b4cb148b-1288-4df4-ba49-260152a6d8ba"],

Cell[BoxData[
 RowBox[{
  TagBox[
   TemplateBox[{"\"Kirill Belov\"", "\" says: \""},
    "RowDefault"],
   "EchoLabel"], "  ", "\<\"Hi! My name is Kirill Belov\"\>"}]], "Echo",
 CellChangeTimes->{
  3.9129223985303144`*^9},ExpressionUUID->"6836f566-9de3-45ca-ae46-\
51da5478221e"],

Cell[BoxData["\<\"Hi! My name is Kirill Belov\"\>"], "Output",
 CellChangeTimes->{3.9129223985303144`*^9},
 CellLabel->"Out[52]=",ExpressionUUID->"3543e377-eaeb-4e77-abdb-6aad134f85f2"],

Cell[BoxData[
 RowBox[{
  TagBox[
   TemplateBox[{"\"Kirill Belov\"", "\" says: \""},
    "RowDefault"],
   "EchoLabel"], 
  "  ", "\<\"Hi! My name is Kirill Belov. What is your name?\"\>"}]], "Echo",
 CellChangeTimes->{
  3.9129223985459423`*^9},ExpressionUUID->"839faada-80ca-469e-86fe-\
f6e624db387b"],

Cell[BoxData["\<\"Hi! My name is Kirill Belov. What is your name?\"\>"], \
"Output",
 CellChangeTimes->{3.9129223985459423`*^9},
 CellLabel->"Out[53]=",ExpressionUUID->"ba0b2379-df47-4b7e-9ccc-c0d1e87d11b6"]
}, Open  ]],

Cell["\<\
It turned out exactly the same as in the C# example. But that\
\[CloseCurlyQuote]s not all. The thing is that WL definitions don\
\[CloseCurlyQuote]t use signatures. They use patterns. And patterns are an \
entire internal language. It\[CloseCurlyQuote]s like pattern-matching from \
functional languages, only patterns can be directly specified in the function \
definition instead of being checked in the body.\
\>", "Text",
 CellChangeTimes->{
  3.9129224099102077`*^9},ExpressionUUID->"a470dc4f-e495-4532-b74b-\
742e36845125"],

Cell["\<\
For example like this I can create a function where the pattern will be much \
more complex than just a signature:\
\>", "Text",
 CellChangeTimes->{
  3.9129224193213387`*^9},ExpressionUUID->"5c77809f-15ec-47b9-9ef8-\
b16312126db9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{
    RowBox[{"addPets", "[", 
     RowBox[{"human_Human", ",", 
      RowBox[{"pets", ":", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_String", ",", "_"}], "}"}], ".."}], "}"}]}]}], "]"}], "/;", 
    RowBox[{"AssociationQ", "[", 
     RowBox[{"human", "[", "\"\<Pets\>\"", "]"}], "]"}]}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"petName", "=", 
         RowBox[{"pet", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"human", "[", 
         RowBox[{"\"\<Pets\>\"", ",", "petName"}], "]"}], "=", "pet"}]}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"pet", ",", "pets"}], "}"}]}], "]"}]}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{"addPets", "[", 
    RowBox[{"human_Human", ",", "pets_"}], "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"human", "[", "\"\<Pets\>\"", "]"}], "=", 
      RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"addPets", "[", 
      RowBox[{"human", ",", "pets"}], "]"}]}], ")"}]}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"addPets", "[", 
  RowBox[{"Kirill", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<Robet\>\"", ",", 
       RowBox[{"Dog", "[", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Jessica\>\"", ",", 
       RowBox[{"Cat", "[", "]"}]}], "}"}]}], "}"}]}], "]"}], "\n", 
 RowBox[{"Kirill", "[", "\"\<Pets\>\"", "]"}]}], "Input",
 CellChangeTimes->{{3.9129224314559903`*^9, 3.9129224314715824`*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"77b3cf1c-37d3-4ea0-a5ee-eed3dbdda34b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\<\"Robet\"\>", ",", 
     RowBox[{"Dog", "[", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"Jessica\"\>", ",", 
     RowBox[{"Cat", "[", "]"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.912922432074396*^9},
 CellLabel->"Out[56]=",ExpressionUUID->"aaf14a50-7d86-4e83-b1e5-68b6bafc1432"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Robet\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\<\"Robet\"\>", ",", 
      RowBox[{"Dog", "[", "]"}]}], "}"}]}], ",", 
   RowBox[{"\<\"Jessica\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\<\"Jessica\"\>", ",", 
      RowBox[{"Cat", "[", "]"}]}], "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.912922432074396*^9},
 CellLabel->"Out[57]=",ExpressionUUID->"d4ce648b-636a-48a8-a861-f10bdab89163"]
}, Open  ]],

Cell[TextData[{
 "What do we see above? The definition in the list is not simply searched by \
signature. In this case, the argument is first compared to the pattern ",
 StyleBox["{{_String, _}.. }",
  FontWeight->"Bold"],
 ", which means a list of lists with two elements on the second level and the \
first one being a string. Additionally, after this comparison, it is checked \
that the human object has the property ",
 StyleBox["\[OpenCurlyDoubleQuote]Pets\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 " and that it is an association. This way of creating definitions is much \
more flexible than using signatures. But there are some disadvantages - \
searching for functions by patterns is slower than by signatures. Besides the \
fact that we can extend a signature with a template - i.e. turn it into \
something more complex in structure - we can also narrow the signature. A \
typical signature indicates that a function takes an argument of a certain \
type, i.e. it is a range of possible values. A pattern can be one specific \
value. This means that I can create such a function-method:"
}], "Text",
 CellChangeTimes->{{3.912922450614668*^9, 
  3.912922464191352*^9}},ExpressionUUID->"f91c2e4e-1d53-418f-9c79-\
52158fa00125"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{"getName", "[", 
    RowBox[{"human_Human", ",", "\"\<first\>\""}], "]"}], ":=", 
   RowBox[{
    RowBox[{"StringSplit", "[", 
     RowBox[{"human", "[", "\"\<Name\>\"", "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{"getName", "[", 
    RowBox[{"human_Human", ",", "\"\<last\>\""}], "]"}], ":=", 
   RowBox[{
    RowBox[{"StringSplit", "[", 
     RowBox[{"human", "[", "\"\<Name\>\"", "]"}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"-", "1"}], "]"}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"getName", "[", 
  RowBox[{"Kirill", ",", "\"\<first\>\""}], "]"}], "\n", 
 RowBox[{"getName", "[", 
  RowBox[{"Kirill", ",", "\"\<second\>\""}], "]"}], "\n", 
 RowBox[{"getName", "[", 
  RowBox[{"Kirill", ",", "\"\<last\>\""}], "]"}]}], "Input",
 CellChangeTimes->{{3.912922480090908*^9, 3.912922480090908*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"fb5541f3-e53c-428c-b80d-c7f96a5335b3"],

Cell[BoxData["\<\"Kirill\"\>"], "Output",
 CellChangeTimes->{3.9129224811347246`*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"247e361c-3ee8-4f72-8cc1-bab9325a646d"],

Cell[BoxData[
 RowBox[{"getName", "[", 
  RowBox[{
   InterpretationBox[
    RowBox[{
     TagBox["Human",
      "SummaryHead"], "[", 
     DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = 
      "Ready"}, 
      TemplateBox[{
        PaneSelectorBox[{False -> GridBox[{{
              StyleBox[
              "\"\|01f9cd\:200d\[Mars]\:fe0f\"", 22, StripOnInput -> False], 
              GridBox[{{
                 RowBox[{
                   TagBox["\"Self: \"", "SummaryItemAnnotation"], 
                   "\[InvisibleSpace]", 
                   TagBox["Global`Human`$16", "SummaryItem"]}], 
                 "\[SpanFromLeft]"}, {
                 RowBox[{
                   TagBox["\"Properties: \"", "SummaryItemAnnotation"], 
                   "\[InvisibleSpace]", 
                   TagBox[
                    RowBox[{"{", 
                    
                    RowBox[{
                    "\"Icon\"", ",", "\"Init\"", ",", "\"Name\"", ",", 
                    "\"Age\"", ",", "\"Country\"", ",", "\"Self\"", ",", 
                    "\"Properties\"", ",", "\"Pets\""}], "}"}], 
                    "SummaryItem"]}], "\[SpanFromLeft]"}}, 
               GridBoxAlignment -> {
                "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
               False, GridBoxItemSize -> {
                "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
               GridBoxSpacings -> {
                "Columns" -> {{2}}, "Rows" -> {{Automatic}}}, 
               BaseStyle -> {
                ShowStringCharacters -> False, NumberMarks -> False, 
                 PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
            GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
            AutoDelete -> False, 
            GridBoxItemSize -> {
             "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
            BaselinePosition -> {1, 1}], True -> GridBox[{{
              StyleBox[
