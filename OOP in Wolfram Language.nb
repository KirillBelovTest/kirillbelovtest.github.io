Cell["\<\
It\[CloseCurlyQuote]s really just a function that returns an object with the \
same header, but it gives it an internal structure. In this respect, I\
\[CloseCurlyQuote]ve done something similar to objects in JavaScript, where \
in the same way the constructor is a function that returns an object. Notice \
that the printed object in the output cell lists its properties. I have \
provided the ability to set these properties to specific values in the \
constructor using option syntax, which works like most Wolfram Language \
functions:\
\>", "Text",
 CellChangeTimes->{
  3.912921106339914*^9},ExpressionUUID->"65e82524-d1e9-457e-8ce7-\
f44bf18fb983"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"obj2", "=", 
  RowBox[{"Object", "[", 
   RowBox[{"\"\<Icon\>\"", "->", 
    RowBox[{"Graphics3D", "[", 
     RowBox[{
      RowBox[{"Sphere", "[", "]"}], ",", 
      RowBox[{"Boxed", "->", "False"}]}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.912921114578232*^9, 3.912921114578232*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"79602dd7-384d-432c-861a-c09635145859"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["Object",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            Graphics3DBox[
             SphereBox[{0, 0, 0}], Boxed -> False], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Self: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["KirillBelov`Objects`Object`$12", "SummaryItem"]}], 
               "\[SpanFromLeft]"}, {
               RowBox[{
                 TagBox["\"Properties: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  RowBox[{"{", 
                    
                    RowBox[{
                    "\"Icon\"", ",", "\"Init\"", ",", "\"Self\"", ",", 
                    "\"Properties\""}], "}"}], "SummaryItem"]}], 
               "\[SpanFromLeft]"}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}], True -> GridBox[{{
            Graphics3DBox[
