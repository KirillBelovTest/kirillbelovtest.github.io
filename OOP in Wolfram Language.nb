Cell[TextData[{
 "As we can see above, if even a human being knows how to say \
\[OpenCurlyDoubleQuote]hello\[CloseCurlyDoubleQuote], the student is deprived \
of this ability. Although he has completely inherited all the properties of a \
human being, but the functions defined on him are not. What is the matter? \
The point is in binding. The ",
 StyleBox["sayHi",
  FontWeight->"Bold"],
 " function has a global definition and strong typing. In fact, the ",
 StyleBox["Human",
  FontWeight->"Bold"],
 " type knows nothing at all about what functions have been defined on it. \
This is not so bad as it seems at first sight, as it gives you a choice not \
to carry a bunch of definitions for each object, which it does not need, but \
to create something specific for the type without changing the type itself. \
In general, we can argue about it for a long time. The most important thing \
is that I have shown the problem and explained it. Is there a solution? \
Naturally! Besides linking a definition with a function, we can also link it \
with the type itself using ",
 StyleBox["UpValues",
  FontWeight->"Bold"],
 "! To create such a definition, we need to use a slightly different syntax, \
where we need to specify the actual symbol-type to which the definition \
should be bound:"
}], "Text",
 CellChangeTimes->{
  3.9129221093331213`*^9},ExpressionUUID->"9ec84113-a33d-492d-ac08-\
8975470f3d6b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "sayHi", "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{"sayHi", "[", "human_Human", "]"}], ":=", 
   RowBox[{"Echo", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringTemplate", "[", "\"\<Hi! My name is `1`\>\"", "]"}], "[", 
      RowBox[{"human", "[", "\"\<Name\>\"", "]"}], "]"}], ",", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"human", "[", "\"\<Name\>\"", "]"}], ",", "\"\< says: \>\""}],
        "}"}], "]"}]}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"sayHi", "[", "Kirill", "]"}]}], "Input",
 CellChangeTimes->{{3.9129221653291802`*^9, 3.9129221653291802`*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"15d308fb-8f64-4fd9-9e75-32fb68266c99"],

Cell[BoxData[
 RowBox[{
  TagBox[
   TemplateBox[{"\"Kirill Belov\"", "\" says: \""},
    "RowDefault"],
   "EchoLabel"], "  ", "\<\"Hi! My name is Kirill Belov\"\>"}]], "Echo",
 CellChangeTimes->{
  3.9129221667625027`*^9},ExpressionUUID->"fbd1b5ff-d72c-4c87-b0a9-\
5288ea9a2172"],

Cell[BoxData["\<\"Hi! My name is Kirill Belov\"\>"], "Output",
 CellChangeTimes->{3.912922166776546*^9},
 CellLabel->"Out[44]=",ExpressionUUID->"9275ca0e-537e-448f-bcc1-465db0af8bc6"]
}, Open  ]],

Cell[TextData[{
 "So far, everything works exactly the same. Only the syntax of creating a \
function (now we can call it a method) has changed a bit. At the very \
beginning we specified ",
 StyleBox["Human /: ",
  FontWeight->"Bold"],
 "to show what the definition is bound to. This will work ONLY if the \
definition has the form ",
 StyleBox["f[x_MyType] := ...",
  FontWeight->"Bold"],
 ", i.e. so that the object itself is at the first level in the body of the \
template and only there. I.e. it won\[CloseCurlyQuote]t work like that anymore"
}], "Text",
 CellChangeTimes->{
  3.9129221799349313`*^9},ExpressionUUID->"a983fe63-3efb-4261-8621-\
3c8f54ce6cec"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Human", "/:", 
   RowBox[{"human_Human", "[", "]"}], ":=", 
   RowBox[{"{", "}"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"Human", " ", "on", " ", "level", " ", "0"}], "*)"}]}], "\n", 
 RowBox[{"Human", "/:", 
  RowBox[{"f", "[", 
   RowBox[{"g", "[", 
    RowBox[{"human_Human", "[", "]"}], "]"}], "]"}], ":=", 
  RowBox[{"{", "}"}], " ", 
  RowBox[{"(*", 
   RowBox[{"on", " ", "level", " ", "2"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9129222033635173`*^9, 
  3.912922226939868*^9}},ExpressionUUID->"e32fbe05-096b-4714-bc2d-\
1c0b25937709"],

Cell[BoxData[
 TemplateBox[{
  "TagSetDelayed", "tagpos", 
   "\"Tag \\!\\(\\*RowBox[{\\\"Human\\\"}]\\) in \\!\\(\\*RowBox[{\\\"f\\\", \
\\\"[\\\", RowBox[{\\\"g\\\", \\\"[\\\", RowBox[{\\\"human_Human\\\", \\\"[\\\
\", \\\"]\\\"}], \\\"]\\\"}], \\\"]\\\"}]\\) is too deep for an assigned rule \
to be found.\"", 2, 46, 3, 19648033680653536117, "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellChangeTimes->{3.9129222054101505`*^9},
 CellLabel->
  "During evaluation of \
In[45]:=",ExpressionUUID->"c2b49f72-d3c0-4c83-ac0a-a34e57e6bfd4"],

Cell[BoxData["$Failed"], "Output",
 CellChangeTimes->{3.9129222054256053`*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"123244eb-134b-4ab6-80d2-f6d4ffef4eee"]
}, Open  ]],

Cell["\<\
The definition created in this way was not bound to a function, but to a \
Human type. Here is how to check it:\
\>", "Text",
 CellChangeTimes->{
  3.9129222371725655`*^9},ExpressionUUID->"7d319256-1367-4c5e-9ae2-\
eb2d5a31de90"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"UpValues", "[", "Human", "]"}], ",", 
   RowBox[{"_", "[", 
    RowBox[{
     RowBox[{"_", "[", 
      RowBox[{"sayHi", "[", "_", "]"}], "]"}], ",", "_"}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9129222412394867`*^9, 3.9129222412394867`*^9}},
 CellLabel->"In[47]:=",ExpressionUUID->"ba8c59ea-6fd5-419a-95fe-15d68c6c6a51"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"HoldPattern", "[", 
    RowBox[{"sayHi", "[", "human_Human", "]"}], "]"}], "\[RuleDelayed]", 
   RowBox[{"Echo", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringTemplate", "[", "\<\"Hi! My name is `1`\"\>", "]"}], "[", 
      RowBox[{"human", "[", "\<\"Name\"\>", "]"}], "]"}], ",", 
     TemplateBox[{
       RowBox[{"human", "[", "\"Name\"", "]"}], "\" says: \""},
      "RowDefault"]}], "]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9129222416807323`*^9},
 CellLabel->"Out[47]=",ExpressionUUID->"6647403d-81cb-4988-b5dc-41d67a2c5c05"]
}, Open  ]],

Cell["\<\
And now, if we create the Student type again, the definition of sayHi is \
inherited:\
\>", "Text",
 CellChangeTimes->{
  3.9129222572515955`*^9},ExpressionUUID->"35d7d8dc-8917-41a5-88bc-\
e9a8bf572d19"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"CreateType", "[", 
   RowBox[{"Student", ",", "Human", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<Course\>\"", "->", "1"}], "}"}]}], "]"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ivan", "=", 
   RowBox[{"Student", "[", 
    RowBox[{"\"\<Name\>\"", "->", "\"\<Ivan\>\""}], "]"}]}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"sayHi", "[", "Ivan", "]"}]}], "Input",
 CellChangeTimes->{{3.912922262366829*^9, 3.912922262366829*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"fa9fa833-7361-4f3a-a048-592a840d917e"],

