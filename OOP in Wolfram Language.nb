Cell["\<\
In fact, what I\[CloseCurlyQuote]ve shown above is already very suspiciously \
similar to Association - a built-in data structure in WL and analog of dict \
from Python. It is - objects do work using this structure, but the \
association itself is immutable and is always copied in its entirety. And \
objects are mutable and you can create many references to a single object and \
mutate it from different places. Below is a visual demonstration of the \
differences:\
\>", "Text",
 CellChangeTimes->{
  3.91292130604045*^9},ExpressionUUID->"36d6e949-4dd5-4315-bd1c-1360b3fc2ae2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"obj1", "=", 
   RowBox[{"Object", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"obj2", "=", "obj1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"obj1", "[", "\"\<Icon\>\"", "]"}], "=", 
   RowBox[{"ColorSeparate", "[", 
    RowBox[{
     RowBox[{"obj1", "[", "\"\<Icon\>\"", "]"}], ",", "\"\<L\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{"obj1", ",", "obj2"}], "}"}]}], "Input",
 CellChangeTimes->{{3.9129213119415274`*^9, 3.9129213119415274`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"2acc4e42-f842-457d-a7e2-ec086dd231b8"],

