Cell["If I try to do the same thing with associations:", "Text",
 CellChangeTimes->{
  3.9129213360771627`*^9},ExpressionUUID->"e4d14647-be7d-463f-a52e-\
efd2d83c9875"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"assoc1", "=", 
   RowBox[{"<|", 
    RowBox[{"\"\<Name\>\"", "->", "\"\<Assoc1\>\""}], "|>"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"assoc2", "=", "assoc1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"assoc1", "[", "\"\<Name\>\"", "]"}], "=", "\"\<New Assoc1\>\""}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{"assoc1", ",", "assoc2"}], "}"}]}], "Input",
 CellChangeTimes->{{3.9129213440550575`*^9, 3.9129213440550575`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"da1f1d30-9e94-4deb-b069-daa6850ad982"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\[LeftAssociation]", 
    RowBox[{"\<\"Name\"\>", "\[Rule]", "\<\"New Assoc1\"\>"}], 
    "\[RightAssociation]"}], ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{"\<\"Name\"\>", "\[Rule]", "\<\"Assoc1\"\>"}], 
    "\[RightAssociation]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.912921345173112*^9},
 CellLabel->"Out[23]=",ExpressionUUID->"79972d27-be5e-41ed-89f4-4f657b4f221f"]
}, Open  ]],

Cell["\<\
Then the variable to which the association was copied will not change in any \
way. I am referring to Python and here is how such code will work in it:\
\>", "Text",
 CellChangeTimes->{
  3.912921388082703*^9},ExpressionUUID->"f132baba-bfd7-4957-986b-\
37c818acc2dd"],

Cell[CellGroupData[{

Cell["\<\
dict1 = {\"Name\": \"Dict 1\"}; 
dict2 = dict1; 
dict1[\"Name\"] = \"New Dict 1\"; 
print([dict1, dict2])\
\>", "ExternalLanguage",
 CellChangeTimes->{3.912921399961464*^9},
 CellLabel->"In[25]:=",ExpressionUUID->"6da8f106-c323-4e4b-8c23-96c8ee76a285"],

Cell[BoxData["\<\"[{'Name': 'New Dict 1'}, {'Name': 'New Dict 1'}]\"\>"], \
"Print",
 CellChangeTimes->{3.91292163207483*^9},
 CellLabel->
  "During evaluation of \
In[25]:=",ExpressionUUID->"e28860ba-96d7-4bcb-952c-e439e5810066"]
}, Open  ]],

Cell["\<\
Furthermore, I don\[CloseCurlyQuote]t even need to create a \
\[OpenCurlyDoubleQuote]reference\[CloseCurlyDoubleQuote] to the object to \
work with it. I can just create an object in a cell and not save it to a \
variable like this:\
\>", "Text",
 CellChangeTimes->{
  3.9129216650032325`*^9},ExpressionUUID->"1e71e350-42bb-4397-9ca6-\
78b5aaea5da1"],

