Cell[TextData[{
 "Note that in the ",
 StyleBox["\[OpenCurlyDoubleQuote]Properties\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 " list, both the property names from ",
 StyleBox["Object",
  FontWeight->"Bold"],
 " and the new ones we just set to the type appeared. That is, the properties \
were inherited!"
}], "Text",
 CellChangeTimes->{
  3.9129218634831867`*^9},ExpressionUUID->"06ed70be-296e-47ff-8a8b-\
dbbe438a91fe"],

Cell["\<\
Only the first argument to the CreateType function is mandatory - it must be \
a character that denotes the new type. All other arguments are default:\
\>", "Text",
 CellChangeTimes->{
  3.912921891447764*^9},ExpressionUUID->"516978c4-2f62-44ee-b510-\
52ea002fae8e"],

Cell[TextData[{
 StyleBox["parent",
  FontWeight->"Bold"],
 " - inherit from ",
 StyleBox["Object",
  FontWeight->"Bold"],
 " by default"
}], "Item",
 CellChangeTimes->{
  3.91292190709692*^9},ExpressionUUID->"4db38c81-3afa-4bc1-a6d1-4bdf455f8399"],

Cell[TextData[{
 StyleBox["init",
  FontWeight->"Bold"],
 " - by default it is Identity - in fact the function does nothing"
}], "Item",
 CellChangeTimes->{
  3.9129219127097025`*^9},ExpressionUUID->"82d621d8-7512-49ce-88dd-\
fd6c391af38b"],

Cell[TextData[{
 StyleBox["fields",
  FontWeight->"Bold"],
 " - by default an empty list ",
 StyleBox["{}",
  FontWeight->"Bold"]
}], "Item",
 CellChangeTimes->{{3.91292190370921*^9, 
  3.9129219109789844`*^9}},ExpressionUUID->"96802ae1-94ee-4086-88c7-\
73601defcaa2"],

Cell[TextData[{
 "It should be noted that the parent type must be an existing type, and the \
properties are specified as a list of rules or a list of names. Where there \
is a rule instead of a name (as for ",
 StyleBox["\[OpenCurlyDoubleQuote]Country\[CloseCurlyDoubleQuote]",
  FontWeight->"Bold"],
 "), the right-hand side will be used by default. Where only the name (string \
or character) - the default property value will be ",
 StyleBox["Automatic",
  FontWeight->"Bold"],
 ". In general it\[CloseCurlyQuote]s strange that I created the type \
\[OpenCurlyDoubleQuote]person\[CloseCurlyDoubleQuote], but it still has the \
old icon with Spikey\[CloseCurlyQuote]s drawing. Is there any way to change \
it? Sure! For any property of the parent type you can override the default \
value like this:"
}], "Text",
 CellChangeTimes->{
  3.9129219527119427`*^9},ExpressionUUID->"055c9c77-845f-4e91-80b0-\
3d16af8250c8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"CreateType", "[", 
   RowBox[{"Human", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<Name\>\"", ",", "Age", ",", 
      RowBox[{"\"\<Country\>\"", "->", 
       RowBox[{"Entity", "[", 
        RowBox[{"\"\<Country\>\"", ",", "\"\<Russia\>\""}], "]"}]}], ",", 
      RowBox[{"\"\<Icon\>\"", "->", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<\|01f9cd\:200d\[Mars]\:fe0f\>\"", ",", "22"}], "]"}]}]}],
      "}"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Kirill", "=", 
  RowBox[{"Human", "[", 
   RowBox[{"\"\<Name\>\"", "->", "\"\<Kirill Belov\>\""}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9129219700228357`*^9, 3.9129219700382843`*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"d824f95a-27f5-401c-94f0-8be1fbbfb3ba"],

Cell[BoxData["Human"], "Output",
 CellChangeTimes->{3.9129219711928535`*^9},
 CellLabel->"Out[33]=",ExpressionUUID->"ff114550-a4da-48ca-a324-641e994e12d7"],

