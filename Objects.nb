sexFactor[{e1___, e2__ ~~ x__, e3___, e4__ ~~ x__, e5___}] := 
 sexFactor[{Flatten[{e2, e4}, 1] ~~ x, e1, e3, e5}]

sexFactor[s : {__}] := s
```

