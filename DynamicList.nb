Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"createDynamicList", "[", "]"}], " ", ":=", " ", "\n", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ref", " ", "=", " ", 
        RowBox[{"Unique", "[", "\"\<DYNAMICLIST`$\>\"", "]"}]}], "}"}], ",", 
      " ", "\n", "\t", 
      RowBox[{
       RowBox[{"ref", " ", "=", " ", 
        RowBox[{"<|", "\n", "\t\t", 
         RowBox[{
          RowBox[{"\"\<Data\>\"", " ", "->", " ", 
           RowBox[{"{", "0", "}"}]}], ",", " ", "\n", "\t\t", 
