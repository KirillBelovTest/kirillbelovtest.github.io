          "\t\t", 
          RowBox[{"\"\<Capacity\>\"", " ", "->", " ", "1"}]}], "\n", "\t", 
         "|>"}]}], ";", " ", "\n", "\t", 
       RowBox[{"DynamicList", "[", "ref", "]"}]}]}], "\n", "]"}]}], ";"}], 
  " "}]], "Code",
