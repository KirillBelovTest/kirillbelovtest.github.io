Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DynamicList", " ", "/:", " ", 
    RowBox[{"append", "[", 
     RowBox[{
      RowBox[{"DynamicList", "[", "ref_Symbol", "]"}], ",", " ", "item_"}], 
     "]"}], " ", ":=", " ", "\n", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"len", " ", "=", " ", 
         RowBox[{"ref", "[", "\"\<Length\>\"", "]"}]}], ",", " ", 
        RowBox[{"capacity", " ", "=", " ", 
         RowBox[{"ref", "[", "\"\<Capacity\>\"", "]"}]}]}], "}"}], ",", " ", 
      "\n", "\t", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"len", " ", "===", " ", "capacity"}], ",", " ", "\n", "\t\t", 
         RowBox[{
          RowBox[{
           RowBox[{"ref", "[", "\"\<Data\>\"", "]"}], " ", "=", " ", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"ref", "[", "\"\<Data\>\"", "]"}], ",", " ", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", " ", "len"}], "]"}]}], "]"}]}], ";", " ", 
          "\n", "\t\t", 
          RowBox[{
           RowBox[{"ref", "[", "\"\<Capacity\>\"", "]"}], " ", "=", " ", 
           RowBox[{"capacity", " ", "*", " ", "2"}]}], ";"}]}], " ", "\n", 
        "\t", "]"}], ";", " ", "\n", "\t", 
       RowBox[{
        RowBox[{"ref", "[", "\"\<Length\>\"", "]"}], " ", "=", " ", 
        RowBox[{"len", " ", "+", " ", "1"}]}], ";", " ", "\n", "\t", 
       RowBox[{
        RowBox[{"ref", "[", 
         RowBox[{"[", 
          RowBox[{"\"\<Data\>\"", ",", " ", 
