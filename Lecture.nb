Cell[BoxData[
 RowBox[{
  RowBox[{"myImport", "[", "dir_String", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "files", ",", " ", "fileLen", ",", " ", "file", ",", " ", "text", ",", 
      " ", "lines", ",", " ", "lineLen", ",", " ", "columns", ",", " ", 
      "columnLen", ",", " ", "line"}], "}"}], ",", " ", "\[IndentingNewLine]",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"files", " ", "=", " ", 
      RowBox[{"FileNames", "[", 
       RowBox[{"\"\<*.txt\>\"", ",", " ", 
        RowBox[{"{", "dir", "}"}]}], "]"}]}], ";", " ", "\[IndentingNewLine]", 
     RowBox[{"fileLen", " ", "=", " ", 
      RowBox[{"Length", "[", "files", "]"}]}], ";", " ", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"file", " ", "=", " ", 
         RowBox[{"files", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], ";", " ", "\[IndentingNewLine]", 
        RowBox[{"text", " ", "=", " ", 
         RowBox[{"Import", "[", 
          RowBox[{"file", ",", " ", "\"\<String\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"lines", " ", "=", " ", 
         RowBox[{"Rest", "[", 
          RowBox[{"StringSplit", "[", 
           RowBox[{"text", ",", " ", "\"\<\\n\>\""}], "]"}], "]"}]}], ";", 
        " ", "\[IndentingNewLine]", 
        RowBox[{"lineLen", " ", "=", " ", 
         RowBox[{"Length", "[", "lines", "]"}]}], ";", " ", 
        "\[IndentingNewLine]", 
        RowBox[{"file", " ", "->", " ", 
         RowBox[{"Table", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"line", " ", "=", " ", 
             RowBox[{"StringTrim", "[", 
              RowBox[{"lines", "[", 
               RowBox[{"[", "j", "]"}], "]"}], "]"}]}], ";", " ", 
            "\[IndentingNewLine]", 
            RowBox[{"columns", " ", "=", " ", 
             RowBox[{"StringSplit", "[", 
              RowBox[{"line", ",", " ", "\"\< \>\""}], "]"}]}], ";", " ", 
            "\[IndentingNewLine]", 
            RowBox[{"columnLen", " ", "=", " ", 
             RowBox[{"Length", "[", "columns", "]"}]}], ";", 
            "\[IndentingNewLine]", 
