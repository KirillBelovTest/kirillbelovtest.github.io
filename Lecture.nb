Cell[BoxData[
 RowBox[{
  RowBox[{"myImport", "[", "dir_String", "]"}], " ", ":=", " ", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"files", " ", "=", " ", 
     RowBox[{"FileNames", "[", 
      RowBox[{"\"\<*.txt\>\"", ",", " ", 
       RowBox[{"{", "dir", "}"}]}], "]"}]}], ";", " ", "\[IndentingNewLine]", 
    RowBox[{"fileLen", " ", "=", " ", 
     RowBox[{"Length", "[", "files", "]"}]}], ";", " ", "\[IndentingNewLine]", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"file", " ", "=", " ", 
        RowBox[{"files", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], ";", " ", "\[IndentingNewLine]", 
       RowBox[{"text", " ", "=", " ", 
        RowBox[{"Import", "[", 
         RowBox[{"file", ",", " ", "\"\<String\>\""}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"lines", " ", "=", " ", 
        RowBox[{"Rest", "[", 
         RowBox[{"StringSplit", "[", 
          RowBox[{"text", ",", " ", "\"\<\\n\>\""}], "]"}], "]"}]}], ";", " ",
