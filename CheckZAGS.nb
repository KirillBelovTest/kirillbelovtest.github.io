Cell[BoxData[
 RowBox[{
  RowBox[{"check", "[", "]"}], " ", ":=", " ", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "\"\<OpenPage\>\"", "\[Rule]", "\"\<https://gosuslugi.ru\>\""}], 
       "}"}]}], "]"}], ";", " ", "\[IndentingNewLine]", 
    RowBox[{"Pause", "[", "15", "]"}], ";", " ", "\n", 
    RowBox[{"draftLink", " ", "=", " ", 
     RowBox[{
      RowBox[{"WebExecute", "[", 
       RowBox[{"session", ",", " ", 
        RowBox[{"\"\<LocateElements\>\"", " ", "->", " ", 
         RowBox[{
         "\"\<XPath\>\"", " ", "->", " ", 
          "\"\<//a[contains(@href,'draft')]\>\""}]}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", " ", "\n", 
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<ClickElement\>\"", "\[Rule]", "draftLink"}], "}"}]}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Pause", "[", "15", "]"}], ";", " ", "\n", 
    RowBox[{"button8", " ", "=", " ", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"WebExecute", "[", 
        RowBox[{"session", ",", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<LocateElements\>\"", "\[Rule]", 
           RowBox[{
           "\"\<XPath\>\"", " ", "->", " ", "\[IndentingNewLine]", 
            "\"\<//epgu-constructor-day-selector//div[./span[text()='8']]\>\"\
"}]}], "}"}]}], "]"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", " ", "\n", 
    RowBox[{"htmlClass", " ", "=", " ", 
     RowBox[{"WebExecute", "[", 
      RowBox[{"session", ",", " ", 
       RowBox[{"\"\<ElementAttribute\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"button8", ",", " ", "\"\<class\>\""}], "}"}]}]}], "]"}]}], 
    ";", " ", "\n", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"FailureQ", "[", "htmlClass", "]"}]}], ",", " ", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", " ", 
       RowBox[{
        RowBox[{"StringContainsQ", "[", 
         RowBox[{"htmlClass", ",", " ", "\"\<locked\>\""}], "]"}], ",", " ", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Echo", "[", 
          RowBox[{
          "\"\<\:041d\:0435 \:043e\:0441\:0432\:043e\:0431\:043e\:0434\:0438\
\:043b\:043e\:0441\:044c\>\"", ",", " ", 
           "\"\<\:0420\:0415\:0417\:0423\:041b\:042c\:0422\:0410\:0422:\>\""}]\
, "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"sendMessage", "[", 
          RowBox[{"bot", ",", " ", "5282555273", ",", " ", "\"\<closed\>\""}],
           "]"}]}], ",", " ", "\[IndentingNewLine]", 
        RowBox[{"sendMessage", "[", 
         RowBox[{
         "bot", ",", " ", "5282555273", ",", " ", "\"\<ALARM!!!!\>\""}], 
         "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", ")"}]}]], "Input",
 CellChangeTimes->{{3.909758007392302*^9, 3.9097580585151806`*^9}, {
